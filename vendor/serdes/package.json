{
	"name": "@md-oss/serdes",
	"version": "0.10.0",
	"private": false,
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/Mirasaki-OSS/monorepo-template.git",
		"directory": "vendor/serdes"
	},
	"homepage": "https://github.com/Mirasaki-OSS/monorepo-template/tree/main/vendor/serdes#readme",
	"author": {
		"email": "contact@mirasaki.dev",
		"name": "Mirasaki Development",
		"url": "https://mirasaki.dev"
	},
	"type": "module",
	"sideEffects": false,
	"description": "Serializer/Deserializer for JSON, YAML, TOML, MessagePack, and CBOR",
	"license": "ISC",
	"main": "./src/index.ts",
	"files": [
		"dist/**/*",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": "./src/index.ts",
		"./cbor": "./src/cbor.ts",
		"./json": "./src/json.ts",
		"./messagepack": "./src/messagepack.ts",
		"./toml": "./src/toml.ts",
		"./yaml": "./src/yaml.ts"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"main": "./dist/index.cjs",
		"module": "./dist/index.mjs",
		"types": "./dist/index.d.cts",
		"exports": {
			".": {
				"require": {
					"types": "./dist/index.d.cts",
					"default": "./dist/index.cjs"
				},
				"import": {
					"types": "./dist/index.d.mts",
					"default": "./dist/index.mjs"
				}
			},
			"./cbor": {
				"require": {
					"types": "./dist/cbor.d.cts",
					"default": "./dist/cbor.cjs"
				},
				"import": {
					"types": "./dist/cbor.d.mts",
					"default": "./dist/cbor.mjs"
				}
			},
			"./json": {
				"require": {
					"types": "./dist/json.d.cts",
					"default": "./dist/json.cjs"
				},
				"import": {
					"types": "./dist/json.d.mts",
					"default": "./dist/json.mjs"
				}
			},
			"./messagepack": {
				"require": {
					"types": "./dist/messagepack.d.cts",
					"default": "./dist/messagepack.cjs"
				},
				"import": {
					"types": "./dist/messagepack.d.mts",
					"default": "./dist/messagepack.mjs"
				}
			},
			"./toml": {
				"require": {
					"types": "./dist/toml.d.cts",
					"default": "./dist/toml.cjs"
				},
				"import": {
					"types": "./dist/toml.d.mts",
					"default": "./dist/toml.mjs"
				}
			},
			"./yaml": {
				"require": {
					"types": "./dist/yaml.d.cts",
					"default": "./dist/yaml.cjs"
				},
				"import": {
					"types": "./dist/yaml.d.mts",
					"default": "./dist/yaml.mjs"
				}
			}
		}
	},
	"scripts": {
		"build": "pnpm exec md-oss-sync-package-exports && pnpm exec md-oss-apply-package-publish-config && pkgroll --minify --clean-dist --sourcemap  --define.process.env.NODE_ENV='\"production\"' --define.DEBUG=false",
		"clean": "git clean -xdf .turbo dist node_modules tsconfig.tsbuildinfo",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@msgpack/msgpack": "catalog:",
		"cbor-x": "catalog:",
		"smol-toml": "catalog:",
		"yaml": "catalog:"
	},
	"devDependencies": {
		"@md-oss/config": "workspace:^",
		"@md-oss/scripts": "workspace:^",
		"pkgroll": "catalog:",
		"typescript": "catalog:"
	}
}
