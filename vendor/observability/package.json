{
	"name": "@md-oss/observability",
	"version": "0.3.7",
	"private": false,
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/Mirasaki-OSS/monorepo-template.git",
		"directory": "vendor/observability"
	},
	"homepage": "https://github.com/Mirasaki-OSS/monorepo-template/tree/main/vendor/observability#readme",
	"author": {
		"email": "contact@mirasaki.dev",
		"name": "Mirasaki Development",
		"url": "https://mirasaki.dev"
	},
	"type": "module",
	"description": "Structured logging with Pino",
	"license": "ISC",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"files": [
		"dist/**/*",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": {
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			},
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		},
		"./debugger": {
			"require": {
				"types": "./dist/debugger.d.cts",
				"default": "./dist/debugger.cjs"
			},
			"import": {
				"types": "./dist/debugger.d.mts",
				"default": "./dist/debugger.mjs"
			}
		},
		"./env": {
			"require": {
				"types": "./dist/env.d.cts",
				"default": "./dist/env.cjs"
			},
			"import": {
				"types": "./dist/env.d.mts",
				"default": "./dist/env.mjs"
			}
		},
		"./express": {
			"require": {
				"types": "./dist/express.d.cts",
				"default": "./dist/express.cjs"
			},
			"import": {
				"types": "./dist/express.d.mts",
				"default": "./dist/express.mjs"
			}
		},
		"./next-client": {
			"require": {
				"types": "./dist/next-client.d.cts",
				"default": "./dist/next-client.cjs"
			},
			"import": {
				"types": "./dist/next-client.d.mts",
				"default": "./dist/next-client.mjs"
			}
		},
		"./next-server": {
			"require": {
				"types": "./dist/next-server.d.cts",
				"default": "./dist/next-server.cjs"
			},
			"import": {
				"types": "./dist/next-server.d.mts",
				"default": "./dist/next-server.mjs"
			}
		},
		"./types": {
			"require": {
				"types": "./dist/types.d.cts"
			},
			"import": {
				"types": "./dist/types.d.mts"
			}
		}
	},
	"scripts": {
		"build": "pkgroll --minify --clean-dist --sourcemap  --define.process.env.NODE_ENV='\"production\"' --define.DEBUG=false && pnpm exec md-oss-add-module-directive --directive='use client' dist/next-client.mjs dist/next-client.cjs",
		"clean": "git clean -xdf .turbo dist node_modules tsconfig.tsbuildinfo",
		"dev": "tsc --watch",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@md-oss/common": "workspace:^",
		"@md-oss/config": "workspace:^",
		"@md-oss/serdes": "workspace:^",
		"@t3-oss/env-nextjs": "^0.13.11",
		"debug": "^4.4.3",
		"pino": "^10.3.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@md-oss/scripts": "workspace:^",
		"@types/node": "^25.6.0",
		"pkgroll": "^2.27.0",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"@types/debug": "^4.1.13"
	}
}
