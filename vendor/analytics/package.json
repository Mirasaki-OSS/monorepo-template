{
	"name": "@md-oss/analytics",
	"version": "0.10.0",
	"private": false,
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/Mirasaki-OSS/monorepo-template.git",
		"directory": "vendor/analytics"
	},
	"homepage": "https://github.com/Mirasaki-OSS/monorepo-template/tree/main/vendor/analytics#readme",
	"author": {
		"email": "contact@mirasaki.dev",
		"name": "Mirasaki Development",
		"url": "https://mirasaki.dev"
	},
	"type": "module",
	"sideEffects": false,
	"description": "Next.js analytics helpers with Vercel Analytics + optional Google Analytics",
	"license": "ISC",
	"files": [
		"dist/**/*",
		"README.md",
		"LICENSE"
	],
	"exports": {
		"./env": "./src/env.ts",
		"./google": "./src/google.ts",
		"./provider": "./src/provider.ts",
		"./vercel": "./src/vercel.ts"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"exports": {
			"./env": {
				"require": {
					"types": "./dist/env.d.cts",
					"default": "./dist/env.cjs"
				},
				"import": {
					"types": "./dist/env.d.mts",
					"default": "./dist/env.mjs"
				}
			},
			"./google": {
				"require": {
					"types": "./dist/google.d.cts",
					"default": "./dist/google.cjs"
				},
				"import": {
					"types": "./dist/google.d.mts",
					"default": "./dist/google.mjs"
				}
			},
			"./provider": {
				"require": {
					"types": "./dist/provider.d.cts",
					"default": "./dist/provider.cjs"
				},
				"import": {
					"types": "./dist/provider.d.mts",
					"default": "./dist/provider.mjs"
				}
			},
			"./vercel": {
				"require": {
					"types": "./dist/vercel.d.cts",
					"default": "./dist/vercel.cjs"
				},
				"import": {
					"types": "./dist/vercel.d.mts",
					"default": "./dist/vercel.mjs"
				}
			}
		}
	},
	"scripts": {
		"build": "pnpm exec md-oss-sync-package-exports && pnpm exec md-oss-apply-package-publish-config && pkgroll --minify --clean-dist --sourcemap  --define.process.env.NODE_ENV='\"production\"' --define.DEBUG=false",
		"clean": "git clean -xdf .turbo dist node_modules tsconfig.tsbuildinfo",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@next/third-parties": "catalog:",
		"@t3-oss/env-nextjs": "catalog:",
		"@vercel/analytics": "catalog:",
		"react": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@md-oss/config": "workspace:^",
		"@md-oss/scripts": "workspace:^",
		"@types/node": "catalog:",
		"pkgroll": "catalog:",
		"typescript": "catalog:"
	},
	"peerDependencies": {
		"@types/react": "catalog:"
	},
	"peerDependenciesMeta": {
		"@types/react": {
			"optional": true
		}
	}
}
