{
	"name": "@md-oss/cache",
	"version": "0.10.0",
	"private": false,
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/Mirasaki-OSS/monorepo-template.git",
		"directory": "vendor/cache"
	},
	"homepage": "https://github.com/Mirasaki-OSS/monorepo-template/tree/main/vendor/cache#readme",
	"author": {
		"email": "contact@mirasaki.dev",
		"name": "Mirasaki Development",
		"url": "https://mirasaki.dev"
	},
	"type": "module",
	"sideEffects": false,
	"description": "Multi-layer caching with LRU, Redis, and async data fetching support",
	"license": "ISC",
	"main": "./src/index.ts",
	"files": [
		"dist/**/*",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": "./src/index.ts",
		"./async": "./src/async.ts",
		"./env": "./src/env.ts",
		"./keyed-promise-cache": "./src/keyed-promise-cache.ts",
		"./lru": "./src/lru.ts",
		"./manager": "./src/manager.ts",
		"./redis-client": "./src/redis-client.ts",
		"./single-promise-cache": "./src/single-promise-cache.ts",
		"./sliding-async-cache": "./src/sliding-async-cache.ts",
		"./types": "./src/types.ts",
		"./utils": "./src/utils.ts"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"main": "./dist/index.cjs",
		"module": "./dist/index.mjs",
		"types": "./dist/index.d.cts",
		"exports": {
			".": {
				"require": {
					"types": "./dist/index.d.cts",
					"default": "./dist/index.cjs"
				},
				"import": {
					"types": "./dist/index.d.mts",
					"default": "./dist/index.mjs"
				}
			},
			"./async": {
				"require": {
					"types": "./dist/async.d.cts",
					"default": "./dist/async.cjs"
				},
				"import": {
					"types": "./dist/async.d.mts",
					"default": "./dist/async.mjs"
				}
			},
			"./env": {
				"require": {
					"types": "./dist/env.d.cts",
					"default": "./dist/env.cjs"
				},
				"import": {
					"types": "./dist/env.d.mts",
					"default": "./dist/env.mjs"
				}
			},
			"./keyed-promise-cache": {
				"require": {
					"types": "./dist/keyed-promise-cache.d.cts",
					"default": "./dist/keyed-promise-cache.cjs"
				},
				"import": {
					"types": "./dist/keyed-promise-cache.d.mts",
					"default": "./dist/keyed-promise-cache.mjs"
				}
			},
			"./lru": {
				"require": {
					"types": "./dist/lru.d.cts",
					"default": "./dist/lru.cjs"
				},
				"import": {
					"types": "./dist/lru.d.mts",
					"default": "./dist/lru.mjs"
				}
			},
			"./manager": {
				"require": {
					"types": "./dist/manager.d.cts",
					"default": "./dist/manager.cjs"
				},
				"import": {
					"types": "./dist/manager.d.mts",
					"default": "./dist/manager.mjs"
				}
			},
			"./redis-client": {
				"require": {
					"types": "./dist/redis-client.d.cts",
					"default": "./dist/redis-client.cjs"
				},
				"import": {
					"types": "./dist/redis-client.d.mts",
					"default": "./dist/redis-client.mjs"
				}
			},
			"./single-promise-cache": {
				"require": {
					"types": "./dist/single-promise-cache.d.cts",
					"default": "./dist/single-promise-cache.cjs"
				},
				"import": {
					"types": "./dist/single-promise-cache.d.mts",
					"default": "./dist/single-promise-cache.mjs"
				}
			},
			"./sliding-async-cache": {
				"require": {
					"types": "./dist/sliding-async-cache.d.cts",
					"default": "./dist/sliding-async-cache.cjs"
				},
				"import": {
					"types": "./dist/sliding-async-cache.d.mts",
					"default": "./dist/sliding-async-cache.mjs"
				}
			},
			"./types": {
				"require": {
					"types": "./dist/types.d.cts"
				},
				"import": {
					"types": "./dist/types.d.mts"
				}
			},
			"./utils": {
				"require": {
					"types": "./dist/utils.d.cts",
					"default": "./dist/utils.cjs"
				},
				"import": {
					"types": "./dist/utils.d.mts",
					"default": "./dist/utils.mjs"
				}
			}
		}
	},
	"scripts": {
		"build": "pnpm exec md-oss-sync-package-exports && pnpm exec md-oss-apply-package-publish-config && pkgroll --minify --clean-dist --sourcemap  --define.process.env.NODE_ENV='\"production\"' --define.DEBUG=false",
		"clean": "git clean -xdf .turbo dist node_modules tsconfig.tsbuildinfo",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@md-oss/common": "workspace:^",
		"@md-oss/serdes": "workspace:^",
		"@t3-oss/env-core": "catalog:",
		"@types/debug": "catalog:",
		"cache-manager": "catalog:",
		"debug": "catalog:",
		"keyv": "catalog:",
		"lru-cache": "catalog:",
		"redis": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@md-oss/config": "workspace:^",
		"@md-oss/scripts": "workspace:^",
		"@types/node": "catalog:",
		"pkgroll": "catalog:",
		"typescript": "catalog:"
	}
}
