{
	"name": "@md-oss/discord",
	"version": "0.10.0",
	"private": false,
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/Mirasaki-OSS/monorepo-template.git",
		"directory": "vendor/discord"
	},
	"homepage": "https://github.com/Mirasaki-OSS/monorepo-template/tree/main/vendor/discord#readme",
	"author": {
		"email": "contact@mirasaki.dev",
		"name": "Mirasaki Development",
		"url": "https://mirasaki.dev"
	},
	"type": "module",
	"sideEffects": false,
	"description": "Type-safe Discord.js toolkit with component and event registries",
	"license": "ISC",
	"main": "./src/index.ts",
	"files": [
		"dist/**/*",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": "./src/index.ts"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"main": "./dist/index.cjs",
		"module": "./dist/index.mjs",
		"types": "./dist/index.d.cts",
		"exports": {
			".": {
				"require": {
					"types": "./dist/index.d.cts",
					"default": "./dist/index.cjs"
				},
				"import": {
					"types": "./dist/index.d.mts",
					"default": "./dist/index.mjs"
				}
			}
		}
	},
	"scripts": {
		"build": "pnpm exec md-oss-sync-package-exports && pnpm exec md-oss-apply-package-publish-config && pkgroll --minify --clean-dist --sourcemap  --define.process.env.NODE_ENV='\"production\"' --define.DEBUG=false",
		"clean": "git clean -xdf .turbo dist node_modules tsconfig.tsbuildinfo",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@md-oss/common": "workspace:^",
		"@types/debug": "catalog:",
		"debug": "catalog:",
		"discord.js": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@md-oss/config": "workspace:^",
		"@md-oss/scripts": "workspace:^",
		"@types/node": "catalog:",
		"pkgroll": "catalog:",
		"typescript": "catalog:"
	}
}
