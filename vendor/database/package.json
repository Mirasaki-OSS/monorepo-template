{
	"name": "@md-oss/database",
	"version": "0.1.7",
	"private": true,
	"type": "module",
	"description": "Dynamic queries for Drizzle",
	"files": ["dist/**/*", "README.md"],
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"exports": {
		".": {
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			},
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		},
		"./pagination": {
			"require": {
				"types": "./dist/pagination.d.cts",
				"default": "./dist/pagination.cjs"
			},
			"import": {
				"types": "./dist/pagination.d.mts",
				"default": "./dist/pagination.mjs"
			}
		}
	},
	"scripts": {
		"build": "pkgroll --minify --clean-dist --sourcemap  --define.process.env.NODE_ENV='\"production\"' --define.DEBUG=false",
		"clean": "git clean -xdf .turbo dist node_modules tsconfig.tsbuildinfo",
		"dev": "tsc --watch",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@md-oss/config": "workspace:^",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"pkgroll": "^2.21.5",
		"typescript": "^5.9.3"
	}
}
