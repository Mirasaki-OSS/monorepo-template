{
	"name": "@md-oss/database",
	"version": "0.10.0",
	"private": false,
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/Mirasaki-OSS/monorepo-template.git",
		"directory": "vendor/database"
	},
	"homepage": "https://github.com/Mirasaki-OSS/monorepo-template/tree/main/vendor/database#readme",
	"author": {
		"email": "contact@mirasaki.dev",
		"name": "Mirasaki Development",
		"url": "https://mirasaki.dev"
	},
	"type": "module",
	"sideEffects": false,
	"description": "Adapter-agnostic query helpers with typed pagination",
	"license": "ISC",
	"main": "./src/index.ts",
	"files": [
		"dist/**/*",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": "./src/index.ts",
		"./cursor-pagination": "./src/cursor-pagination.ts",
		"./pagination": "./src/pagination.ts"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"main": "./dist/index.cjs",
		"module": "./dist/index.mjs",
		"types": "./dist/index.d.cts",
		"exports": {
			".": {
				"require": {
					"types": "./dist/index.d.cts",
					"default": "./dist/index.cjs"
				},
				"import": {
					"types": "./dist/index.d.mts",
					"default": "./dist/index.mjs"
				}
			},
			"./cursor-pagination": {
				"require": {
					"types": "./dist/cursor-pagination.d.cts",
					"default": "./dist/cursor-pagination.cjs"
				},
				"import": {
					"types": "./dist/cursor-pagination.d.mts",
					"default": "./dist/cursor-pagination.mjs"
				}
			},
			"./pagination": {
				"require": {
					"types": "./dist/pagination.d.cts",
					"default": "./dist/pagination.cjs"
				},
				"import": {
					"types": "./dist/pagination.d.mts",
					"default": "./dist/pagination.mjs"
				}
			}
		}
	},
	"scripts": {
		"build": "pnpm exec md-oss-sync-package-exports && pnpm exec md-oss-apply-package-publish-config && pkgroll --minify --clean-dist --sourcemap  --define.process.env.NODE_ENV='\"production\"' --define.DEBUG=false",
		"clean": "git clean -xdf .turbo dist node_modules tsconfig.tsbuildinfo",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"zod": "catalog:"
	},
	"devDependencies": {
		"@md-oss/config": "workspace:^",
		"@md-oss/scripts": "workspace:^",
		"pkgroll": "catalog:",
		"typescript": "catalog:"
	}
}
