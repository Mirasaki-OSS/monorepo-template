{
	"name": "@md-oss/http-client",
	"version": "0.9.0",
	"private": false,
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/Mirasaki-OSS/monorepo-template.git",
		"directory": "vendor/http-client"
	},
	"homepage": "https://github.com/Mirasaki-OSS/monorepo-template/tree/main/vendor/http-client#readme",
	"author": {
		"email": "contact@mirasaki.dev",
		"name": "Mirasaki Development",
		"url": "https://mirasaki.dev"
	},
	"type": "module",
	"sideEffects": false,
	"description": "Fetch-based HTTP client with retries, timeouts, and typed results",
	"license": "ISC",
	"main": "./src/index.ts",
	"files": [
		"dist/**/*",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": "./src/index.ts",
		"./resolvers": "./src/resolvers.ts",
		"./retry": "./src/retry.ts",
		"./types": "./src/types.ts"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"main": "./dist/index.cjs",
		"module": "./dist/index.mjs",
		"types": "./dist/index.d.cts",
		"exports": {
			".": {
				"require": {
					"types": "./dist/index.d.cts",
					"default": "./dist/index.cjs"
				},
				"import": {
					"types": "./dist/index.d.mts",
					"default": "./dist/index.mjs"
				}
			},
			"./resolvers": {
				"require": {
					"types": "./dist/resolvers.d.cts",
					"default": "./dist/resolvers.cjs"
				},
				"import": {
					"types": "./dist/resolvers.d.mts",
					"default": "./dist/resolvers.mjs"
				}
			},
			"./retry": {
				"require": {
					"types": "./dist/retry.d.cts",
					"default": "./dist/retry.cjs"
				},
				"import": {
					"types": "./dist/retry.d.mts",
					"default": "./dist/retry.mjs"
				}
			},
			"./types": {
				"require": {
					"types": "./dist/types.d.cts"
				},
				"import": {
					"types": "./dist/types.d.mts"
				}
			}
		}
	},
	"scripts": {
		"build": "pnpm exec md-oss-sync-package-exports && pnpm exec md-oss-apply-package-publish-config && pkgroll --minify --clean-dist --sourcemap  --define.process.env.NODE_ENV='\"production\"' --define.DEBUG=false",
		"clean": "git clean -xdf .turbo dist node_modules tsconfig.tsbuildinfo",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@md-oss/common": "workspace:^",
		"@md-oss/serdes": "workspace:^"
	},
	"devDependencies": {
		"@md-oss/config": "workspace:^",
		"@md-oss/scripts": "workspace:^",
		"@types/node": "^25.6.2",
		"pkgroll": "^2.27.0",
		"typescript": "^6.0.3"
	}
}
