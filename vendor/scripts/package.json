{
	"name": "@md-oss/scripts",
	"version": "0.2.2",
	"private": false,
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/Mirasaki-OSS/monorepo-template.git",
		"directory": "vendor/scripts"
	},
	"type": "module",
	"description": "Reusable monorepo maintenance scripts",
	"files": ["dist/**/*", "README.md"],
	"exports": {
		"./find-dependency-mismatches": {
			"require": {
				"types": "./dist/find-dependency-mismatches.d.cts",
				"default": "./dist/find-dependency-mismatches.cjs"
			},
			"import": {
				"types": "./dist/find-dependency-mismatches.d.mts",
				"default": "./dist/find-dependency-mismatches.mjs"
			}
		}
	},
	"scripts": {
		"build": "pkgroll --minify --clean-dist --sourcemap  --define.process.env.NODE_ENV='\"production\"' --define.DEBUG=false",
		"clean": "git clean -xdf .turbo dist node_modules tsconfig.tsbuildinfo",
		"dev": "tsc --watch",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@md-oss/config": "workspace:^"
	},
	"devDependencies": {
		"pkgroll": "^2.27.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2"
	}
}
