{
	"name": "@md-oss/scripts",
	"version": "0.7.1",
	"private": false,
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/Mirasaki-OSS/monorepo-template.git",
		"directory": "vendor/scripts"
	},
	"homepage": "https://github.com/Mirasaki-OSS/monorepo-template/tree/main/vendor/scripts#readme",
	"author": {
		"email": "contact@mirasaki.dev",
		"name": "Mirasaki Development",
		"url": "https://mirasaki.dev"
	},
	"type": "module",
	"sideEffects": false,
	"description": "Reusable monorepo maintenance scripts",
	"license": "ISC",
	"files": [
		"dist/**/*",
		"README.md",
		"LICENSE"
	],
	"bin": {
		"md-oss-find-dependency-mismatches": "./bin/md-oss-find-dependency-mismatches.mjs",
		"md-oss-add-module-directives": "./bin/md-oss-add-module-directives.mjs",
		"md-oss-sync-package-exports": "./bin/md-oss-sync-package-exports.mjs",
		"md-oss-apply-package-publish-config": "./bin/md-oss-apply-package-publish-config.mjs"
	},
	"exports": {
		"./find-dependency-mismatches": "./src/find-dependency-mismatches.ts",
		"./add-module-directives": "./src/add-module-directives.ts",
		"./sync-package-exports": "./src/sync-package-exports.ts",
		"./apply-package-publish-config": "./src/apply-package-publish-config.ts"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"exports": {
			"./find-dependency-mismatches": {
				"require": {
					"types": "./dist/find-dependency-mismatches.d.cts",
					"default": "./dist/find-dependency-mismatches.cjs"
				},
				"import": {
					"types": "./dist/find-dependency-mismatches.d.mts",
					"default": "./dist/find-dependency-mismatches.mjs"
				}
			},
			"./add-module-directives": {
				"require": {
					"types": "./dist/add-module-directives.d.cts",
					"default": "./dist/add-module-directives.cjs"
				},
				"import": {
					"types": "./dist/add-module-directives.d.mts",
					"default": "./dist/add-module-directives.mjs"
				}
			},
			"./sync-package-exports": {
				"require": {
					"types": "./dist/sync-package-exports.d.cts",
					"default": "./dist/sync-package-exports.cjs"
				},
				"import": {
					"types": "./dist/sync-package-exports.d.mts",
					"default": "./dist/sync-package-exports.mjs"
				}
			},
			"./apply-package-publish-config": {
				"require": {
					"types": "./dist/apply-package-publish-config.d.cts",
					"default": "./dist/apply-package-publish-config.cjs"
				},
				"import": {
					"types": "./dist/apply-package-publish-config.d.mts",
					"default": "./dist/apply-package-publish-config.mjs"
				}
			}
		}
	},
	"scripts": {
		"build": "pnpm exec md-oss-sync-package-exports && pnpm exec md-oss-apply-package-publish-config && pkgroll --minify --clean-dist --sourcemap  --define.process.env.NODE_ENV='\"production\"' --define.DEBUG=false",
		"clean": "git clean -xdf .turbo dist node_modules tsconfig.tsbuildinfo",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@md-oss/config": "workspace:^",
		"pkgroll": "^2.27.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	}
}
