{
	"name": "@md-oss/api-types",
	"version": "0.10.0",
	"private": false,
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/Mirasaki-OSS/monorepo-template.git",
		"directory": "vendor/api-types"
	},
	"homepage": "https://github.com/Mirasaki-OSS/monorepo-template/tree/main/vendor/api-types#readme",
	"author": {
		"email": "contact@mirasaki.dev",
		"name": "Mirasaki Development",
		"url": "https://mirasaki.dev"
	},
	"type": "module",
	"sideEffects": false,
	"description": "Type-safe API contracts, client factory, and handler helpers built on Zod",
	"license": "ISC",
	"main": "./src/index.ts",
	"files": [
		"dist/**/*",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": "./src/index.ts",
		"./client": "./src/client.ts",
		"./debugger": "./src/debugger.ts",
		"./params": "./src/params.ts",
		"./request": "./src/request.ts",
		"./response": "./src/response.ts",
		"./route-handler": "./src/route-handler.ts",
		"./types": "./src/types.ts"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"main": "./dist/index.cjs",
		"module": "./dist/index.mjs",
		"types": "./dist/index.d.cts",
		"exports": {
			".": {
				"require": {
					"types": "./dist/index.d.cts",
					"default": "./dist/index.cjs"
				},
				"import": {
					"types": "./dist/index.d.mts",
					"default": "./dist/index.mjs"
				}
			},
			"./client": {
				"require": {
					"types": "./dist/client.d.cts",
					"default": "./dist/client.cjs"
				},
				"import": {
					"types": "./dist/client.d.mts",
					"default": "./dist/client.mjs"
				}
			},
			"./debugger": {
				"require": {
					"types": "./dist/debugger.d.cts",
					"default": "./dist/debugger.cjs"
				},
				"import": {
					"types": "./dist/debugger.d.mts",
					"default": "./dist/debugger.mjs"
				}
			},
			"./params": {
				"require": {
					"types": "./dist/params.d.cts",
					"default": "./dist/params.cjs"
				},
				"import": {
					"types": "./dist/params.d.mts",
					"default": "./dist/params.mjs"
				}
			},
			"./request": {
				"require": {
					"types": "./dist/request.d.cts"
				},
				"import": {
					"types": "./dist/request.d.mts"
				}
			},
			"./response": {
				"require": {
					"types": "./dist/response.d.cts",
					"default": "./dist/response.cjs"
				},
				"import": {
					"types": "./dist/response.d.mts",
					"default": "./dist/response.mjs"
				}
			},
			"./route-handler": {
				"require": {
					"types": "./dist/route-handler.d.cts",
					"default": "./dist/route-handler.cjs"
				},
				"import": {
					"types": "./dist/route-handler.d.mts",
					"default": "./dist/route-handler.mjs"
				}
			},
			"./types": {
				"require": {
					"types": "./dist/types.d.cts"
				},
				"import": {
					"types": "./dist/types.d.mts"
				}
			}
		}
	},
	"scripts": {
		"build": "pnpm exec md-oss-sync-package-exports && pnpm exec md-oss-apply-package-publish-config && pkgroll --minify --clean-dist --sourcemap  --define.process.env.NODE_ENV='\"production\"' --define.DEBUG=false",
		"clean": "git clean -xdf .turbo dist node_modules tsconfig.tsbuildinfo",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@md-oss/common": "workspace:^",
		"@md-oss/http-client": "workspace:^",
		"@md-oss/serdes": "workspace:^",
		"@types/debug": "catalog:",
		"debug": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@md-oss/config": "workspace:^",
		"@md-oss/scripts": "workspace:^",
		"@types/node": "catalog:",
		"pkgroll": "catalog:",
		"typescript": "catalog:"
	}
}
