# ---------------------------------- General ---------------------------------- #
NODE_ENV=production # The node environment your bot is running in. Available values: production, development
NEXT_PUBLIC_APP_NAME="My App" # The name of your site. This is used for display purposes in the UI and emails.
NEXT_PUBLIC_APP_URL="http://localhost:3000" # The base URL of your site. This is used for generating links in emails and other places.
NEXT_PUBLIC_API_URL="http://localhost:4000" # The base URL of your API server. This is used for making API requests from the client.

# ---------------------------------- Docker (Compose) ---------------------------------- #
COMPOSE_FILE=deploy/compose/compose.prod.yaml # The path to the Docker Compose file.
COMPOSE_PROJECT_NAME=my_app # The name of the Docker Compose project.
DOCKER_BUILDKIT=1 # Enable Docker BuildKit for better performance and features.
BUILDKIT_PROGRESS=plain # Show plain build output for better readability.
DOCKER_WEB_PORT=3000 # The port to expose the web service on. Change if you want to use a different port.
DOCKER_SERVER_PORT=4000 # The port to expose the server service on. Change if you want to use a different port.

# ---------------------------------- Authentication (@md-oss/auth) ---------------------------------- #
BETTER_AUTH_SECRET="your-secret-key" # The secret key used for signing and verifying JWT tokens.
CORS_ORIGIN="http://localhost:3000" # The allowed origin for CORS requests.
CLOUDFLARE_TURNSTILE_SECRET_KEY= # The secret key for Cloudflare Turnstile. Required if you want to enable Turnstile for bot protection on your auth forms.
NEXT_PUBLIC_TURNSTILE_SITE_KEY= # The site key for Cloudflare Turnstile. Required if you want to enable Turnstile for bot protection on your auth forms.
DISCORD_CLIENT_ID= # The client ID for Discord OAuth. Required if you want to enable Discord login.
DISCORD_CLIENT_SECRET= # The client secret for Discord OAuth. Required if you want to enable Discord login.
GOOGLE_CLIENT_ID= # The client ID for Google OAuth. Required if you want to enable Google login.
GOOGLE_CLIENT_SECRET= # The client secret for Google OAuth. Required if you want to enable Google login.
GITHUB_CLIENT_ID= # The client ID for GitHub OAuth. Required if you want to enable GitHub login.
GITHUB_CLIENT_SECRET= # The client secret for GitHub OAuth. Required if you want to enable GitHub login.

# ---------------------------------- Database (@md-oss/db) ---------------------------------- #
POSTGRES_HOST=${DB_HOST:-localhost} # Change to "postgres" (service name) if using docker (compose)
POSTGRES_PORT=${DB_PORT:-5432} # The port your PostgreSQL server is running on. Default is 5432.
POSTGRES_USER=${DB_USER:-postgres} # The username for your PostgreSQL server. Default is "postgres".
POSTGRES_PASSWORD=${DB_PASSWORD:-} # The password for your PostgreSQL server.
POSTGRES_DB=my_app_production # The name of the database to connect to. Default is "my_app_production".

# The database URL for connecting to the (PostgreSQL) database. You generally don't
# need to change this, but you can if you want to use a different database or schema.
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public&pgbouncer=true"
