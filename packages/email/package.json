{
	"name": "@md-oss/email",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"sideEffects": false,
	"description": "Email utilities",
	"main": "./src/index.ts",
	"files": [
		"dist/**/*",
		"README.md"
	],
	"exports": {
		".": "./src/index.ts",
		"./env": "./src/env.ts"
	},
	"publishConfig": {
		"main": "./dist/index.cjs",
		"module": "./dist/index.mjs",
		"types": "./dist/index.d.cts",
		"exports": {
			".": {
				"require": {
					"types": "./dist/index.d.cts",
					"default": "./dist/index.cjs"
				},
				"import": {
					"types": "./dist/index.d.mts",
					"default": "./dist/index.mjs"
				}
			},
			"./env": {
				"require": {
					"types": "./dist/env.d.cts",
					"default": "./dist/env.cjs"
				},
				"import": {
					"types": "./dist/env.d.mts",
					"default": "./dist/env.mjs"
				}
			}
		}
	},
	"scripts": {
		"build": "pnpm exec md-oss-sync-package-exports && pnpm exec md-oss-apply-package-publish-config && pkgroll --minify --clean-dist --sourcemap  --define.process.env.NODE_ENV='\"production\"' --define.DEBUG=false",
		"clean": "git clean -xdf .turbo dist node_modules tsconfig.tsbuildinfo",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@md-oss/config": "workspace:^",
		"@md-oss/scripts": "workspace:^",
		"pkgroll": "^2.27.0",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@md-oss/design-system": "workspace:^",
		"@react-email/components": "^1.0.12",
		"@t3-oss/env-core": "^0.13.11",
		"resend": "^6.12.3",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"react": "catalog:",
		"@types/react": "catalog:"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": false
		},
		"@types/react": {
			"optional": false
		}
	}
}
