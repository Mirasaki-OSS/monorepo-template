{
	"name": "@md-oss/authz",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"sideEffects": false,
	"description": "CASL-based RBAC permissions and authorization helpers",
	"main": "./src/index.ts",
	"files": [
		"dist/**/*",
		"README.md"
	],
	"exports": {
		".": "./src/index.ts"
	},
	"publishConfig": {
		"main": "./dist/index.cjs",
		"module": "./dist/index.mjs",
		"types": "./dist/index.d.cts",
		"exports": {
			".": {
				"require": {
					"types": "./dist/index.d.cts",
					"default": "./dist/index.cjs"
				},
				"import": {
					"types": "./dist/index.d.mts",
					"default": "./dist/index.mjs"
				}
			}
		}
	},
	"scripts": {
		"build": "pnpm exec md-oss-sync-package-exports && pnpm exec md-oss-apply-package-publish-config && pkgroll --minify --clean-dist --sourcemap  --define.process.env.NODE_ENV='\"production\"' --define.DEBUG=false",
		"clean": "git clean -xdf .turbo dist node_modules tsconfig.tsbuildinfo",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@md-oss/config": "workspace:^",
		"@md-oss/scripts": "workspace:^",
		"pkgroll": "catalog:",
		"typescript": "catalog:"
	},
	"dependencies": {
		"@casl/ability": "catalog:",
		"@md-oss/common": "workspace:^",
		"@t3-oss/env-core": "catalog:",
		"zod": "catalog:"
	}
}
