{
	"name": "@md-oss/auth",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"sideEffects": false,
	"description": "Authentication using better-auth",
	"files": ["dist/**/*", "README.md"],
	"exports": {
		"./client": {
			"require": {
				"types": "./dist/client/index.d.cts",
				"default": "./dist/client/index.cjs"
			},
			"import": {
				"types": "./dist/client/index.d.mts",
				"default": "./dist/client/index.mjs"
			}
		},
		"./client/env": {
			"require": {
				"types": "./dist/client/env.d.cts",
				"default": "./dist/client/env.cjs"
			},
			"import": {
				"types": "./dist/client/env.d.mts",
				"default": "./dist/client/env.mjs"
			}
		},
		"./server": {
			"require": {
				"types": "./dist/server/index.d.cts",
				"default": "./dist/server/index.cjs"
			},
			"import": {
				"types": "./dist/server/index.d.mts",
				"default": "./dist/server/index.mjs"
			}
		},
		"./server/env": {
			"require": {
				"types": "./dist/server/env.d.cts",
				"default": "./dist/server/env.cjs"
			},
			"import": {
				"types": "./dist/server/env.d.mts",
				"default": "./dist/server/env.mjs"
			}
		}
	},
	"scripts": {
		"build": "pkgroll --minify --clean-dist --sourcemap  --define.process.env.NODE_ENV='\"production\"' --define.DEBUG=false",
		"clean": "git clean -xdf .turbo dist node_modules tsconfig.tsbuildinfo",
		"gen:schema": "pnpm dlx auth@latest generate --config ./src/index.ts --output ../db/src/schema/auth.ts",
		"dev": "pkgroll --watch --sourcemap  --define.process.env.NODE_ENV='\"development\"' --define.DEBUG=true",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@md-oss/config": "workspace:^",
		"pkgroll": "^2.27.0",
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"@md-oss/db": "workspace:^",
		"@t3-oss/env-core": "^0.13.11",
		"better-auth": "^1.6.3",
		"zod": "^4.3.6"
	}
}
