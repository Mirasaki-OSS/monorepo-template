{
	"name": "monorepo",
	"version": "0.0.0",
	"private": true,
	"description": "Modern TypeScript pnpm turbo monorepo",
	"license": "ISC",
	"packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48",
	"engines": {
		"node": ">=18.0.0"
	},
	"scripts": {
		"build": "turbo run build",
		"build:dry": "turbo run build --dry",
		"checks": "pnpm exec biome check --write --unsafe && turbo run typecheck && pnpm script:fdm",
		"checks:ci": "pnpm exec biome ci && pnpm script:fdm && pnpm check:circular",
		"check:circular": "node scripts/node/madge-monorepo.mjs --check=circular",
		"check:orphans": "node scripts/node/madge-monorepo.mjs --check=orphans",
		"clean": "turbo run clean && git clean -xdf node_modules .turbo pnpm-lock.yaml deploy/docker/context-report deploy/compose/.buildx-cache",
		"dev": "turbo run dev",
		"lint": "pnpm exec biome lint --write --unsafe",
		"format": "pnpm exec biome format --write",
		"gen:app": "turbo gen workspace --type app",
		"gen:auth": "pnpm --filter @md-oss/auth gen:schema",
		"gen:migrations": "pnpm --filter @md-oss/db db:generate",
		"gen:dependency-graphs": "node scripts/node/madge-monorepo.mjs --use-graph=workspace --output-dir-base=apps/web/public/dependency-graphs",
		"gen:dependency-graphs:files": "node scripts/node/madge-monorepo.mjs --use-graph=image --output-dir-base=apps/web/public/dependency-graphs/files",
		"gen:dependency-graphs:circular": "node scripts/node/madge-monorepo.mjs --use-graph=circular --output-dir-base=apps/web/public/dependency-graphs/circular",
		"gen:package": "turbo gen package",
		"start": "turbo run start",
		"test": "turbo run test",
		"typecheck": "turbo run typecheck",
		"up:minor": "pnpm up -r && pnpm script:fdm",
		"up:major": "pnpm up -r --latest && pnpm script:fdm",
		"publish:ci": "pnpm run checks:ci && pnpm run build --filter={./vendor/*} && turbo run typecheck --filter={./vendor/*} && changeset version && changeset publish",
		"publish:dryrun": "pnpm -r publish --access public --report-summary --dry-run --no-git-checks",
		"script:fdm": "pnpm dedupe && pnpm exec md-oss-find-dependency-mismatches",
		"script:sl": "tsx ./scripts/node/sync-licenses.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@changesets/cli": "^2.31.0",
		"@md-oss/common": "workspace:^",
		"@md-oss/scripts": "workspace:^",
		"@turbo/gen": "^2.9.12",
		"@types/node": "^25.6.2",
		"glob": "^13.0.6",
		"lefthook": "^2.1.6",
		"madge": "^8.0.0",
		"tsx": "^4.21.0",
		"turbo": "^2.9.12"
	}
}
