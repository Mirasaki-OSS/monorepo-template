{
	"$schema": "./node_modules/turbo/schema.json",
	"ui": "tui",
	"envMode": "strict",
	"globalEnv": ["NODE_ENV"],
	"globalPassThroughEnv": [
		"DATABASE_URL",
		"CORS_ORIGIN",
		"BETTER_AUTH_SECRET",
		"NEXT_PUBLIC_API_URL",
		"DISCORD_CLIENT_ID",
		"DISCORD_CLIENT_SECRET",
		"GOOGLE_CLIENT_ID",
		"GOOGLE_CLIENT_SECRET",
		"GITHUB_CLIENT_ID",
		"GITHUB_CLIENT_SECRET",
		"NEXT_PUBLIC_APP_NAME",
		"NEXT_PUBLIC_APP_URL",
		"CLOUDFLARE_TURNSTILE_SECRET_KEY",
		"NEXT_PUBLIC_TURNSTILE_SITE_KEY"
	],
	"concurrency": "22",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**", "build/**", ".next/**", "!.next/cache/**"],
			"cache": true
		},
		"build:dry": {
			"cache": false
		},
		"clean": {
			"cache": false
		},
		"dev": {
			"cache": false,
			"persistent": true,
			"dependsOn": ["^build"]
		},
		"@md-oss/web#dev": {
			"cache": false,
			"persistent": true,
			"dependsOn": [
				"@md-oss/api#build",
				"@md-oss/auth#build",
				"@md-oss/common#build"
			],
			"with": ["@md-oss/api#dev", "@md-oss/auth#dev", "@md-oss/common#dev"]
		},
		"@md-oss/server#dev": {
			"cache": false,
			"persistent": true,
			"dependsOn": [
				"@md-oss/api#build",
				"@md-oss/auth#build",
				"@md-oss/db#build",
				"@md-oss/utils#build"
			],
			"with": [
				"@md-oss/api#dev",
				"@md-oss/auth#dev",
				"@md-oss/db#dev",
				"@md-oss/utils#dev"
			]
		},
		"@md-oss/cli#dev": {
			"cache": false,
			"persistent": true,
			"dependsOn": ["@md-oss/utils#build"],
			"with": ["@md-oss/utils#dev"]
		},
		"format": {
			"cache": false
		},
		"lint": {
			"dependsOn": ["^lint"],
			"outputs": [".eslintcache"],
			"cache": true
		},
		"start": {
			"cache": false,
			"interactive": true,
			"persistent": true
		},
		"test": {
			"outputs": ["coverage/**"],
			"cache": true
		},
		"typecheck": {
			"dependsOn": ["^build", "^typecheck"],
			"outputs": [],
			"cache": true
		}
	}
}
