{
  "name": "@md-oss/web",
  "version": "0.0.0",
  "description": "Next.js web application",
  "private": true,
  "scripts": {
    "build": "NODE_ENV=production next build",
    "clean": "git clean -xdf .turbo .next .source node_modules tsconfig.tsbuildinfo",
    "dev": "pnpm docs:sync && NODE_ENV=development next dev --port=3000",
    "start": "node .next/standalone/apps/web/server.js",
    "typecheck": "pnpm docs:sync && fumadocs-mdx && next typegen && tsc --noEmit",
    "docs:sync": "node ./scripts/materialize-external-docs.mjs",
    "docs:invariants": "node ./scripts/docs-invariants.mjs",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "@better-auth/api-key": "catalog:",
    "@better-auth/passkey": "catalog:",
    "@hookform/resolvers": "catalog:",
    "@marsidev/react-turnstile": "catalog:",
    "@md-oss/api": "workspace:^",
    "@md-oss/auth": "workspace:^",
    "@md-oss/common": "workspace:^",
    "@md-oss/design-system": "workspace:^",
    "@t3-oss/env-core": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "better-auth": "catalog:",
    "fumadocs-core": "catalog:",
    "fumadocs-mdx": "catalog:",
    "fumadocs-ui": "catalog:",
    "katex": "catalog:",
    "lucide-react": "catalog:",
    "mermaid": "catalog:",
    "next": "catalog:",
    "next-themes": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "catalog:",
    "react-syntax-highlighter": "catalog:",
    "rehype-katex": "catalog:",
    "remark-directive": "catalog:",
    "remark-gfm": "catalog:",
    "remark-github-blockquote-alert": "catalog:",
    "remark-math": "catalog:",
    "sonner": "catalog:",
    "superjson": "catalog:",
    "tailwind-merge": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@fumadocs/cli": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@tailwindcss/typography": "catalog:",
    "@types/mdx": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-syntax-highlighter": "catalog:",
    "postcss": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  }
}
