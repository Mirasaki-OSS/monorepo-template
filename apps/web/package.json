{
  "name": "@md-oss/web",
  "version": "0.0.0",
  "description": "Next.js web application",
  "private": true,
  "scripts": {
    "build": "NODE_ENV=production next build",
    "clean": "git clean -xdf .turbo .next .source node_modules tsconfig.tsbuildinfo",
    "dev": "pnpm docs:sync && NODE_ENV=development next dev --port=3000",
    "start": "node .next/standalone/apps/web/server.js",
    "types:check": "pnpm docs:sync && fumadocs-mdx && next typegen && tsc --noEmit",
    "docs:sync": "node ./scripts/materialize-external-docs.mjs",
    "docs:invariants": "node ./scripts/docs-invariants.mjs",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.10",
    "@better-auth/passkey": "^1.6.10",
    "@hookform/resolvers": "^5.2.2",
    "@marsidev/react-turnstile": "^1.5.2",
    "@md-oss/api": "workspace:^",
    "@md-oss/auth": "workspace:^",
    "@md-oss/common": "workspace:^",
    "@md-oss/design-system": "workspace:^",
    "@t3-oss/env-core": "^0.13.11",
    "@tanstack/react-query": "^5.100.9",
    "@trpc/client": "^11.17.0",
    "@trpc/tanstack-react-query": "^11.17.0",
    "better-auth": "^1.6.10",
    "fumadocs-core": "16.8.9",
    "fumadocs-mdx": "15.0.2",
    "fumadocs-ui": "16.8.9",
    "katex": "^0.16.45",
    "lucide-react": "catalog:",
    "mermaid": "^11.14.0",
    "next": "catalog:",
    "next-themes": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "^7.75.0",
    "react-syntax-highlighter": "catalog:",
    "rehype-katex": "^7.0.1",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@fumadocs/cli": "^1.3.10",
    "@tailwindcss/postcss": "catalog:",
    "@tailwindcss/typography": "^0.5.19",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-syntax-highlighter": "catalog:",
    "postcss": "^8.5.14",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "tailwindcss": "catalog:",
    "typescript": "^6.0.3"
  }
}
