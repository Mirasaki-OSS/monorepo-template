{
	"name": "@md-oss/server",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "API server application",
	"license": "ISC",
	"main": "./dist/index.cjs",
	"scripts": {
		"build": "pkgroll --minify --clean-dist --sourcemap  --define.process.env.NODE_ENV='\"production\"' --define.DEBUG=false",
		"clean": "git clean -xdf .turbo dist node_modules tsconfig.tsbuildinfo",
		"dev": "tsx watch src/index.ts",
		"start": "node ./dist/index.cjs",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@hono/node-server": "catalog:",
		"@hono/trpc-server": "catalog:",
		"@md-oss/api": "workspace:^",
		"@md-oss/auth": "workspace:^",
		"@md-oss/db": "workspace:^",
		"@md-oss/utils": "workspace:^",
		"@t3-oss/env-core": "catalog:",
		"hono": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@md-oss/config": "workspace:^",
		"@types/node": "catalog:",
		"pkgroll": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:"
	}
}
